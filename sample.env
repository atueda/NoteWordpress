# ============================================================
# WordPress 設定（wp-to-note.js で使用）
# ============================================================

# WordPressサイトのURL（末尾スラッシュなし）
WP_URL=https://XXXX.com

# 1回のAPIリクエストで取得する記事数（最大100）
WP_PER_PAGE=20

# 取得するページ数（WP_PER_PAGE × WP_MAX_PAGES = 最大取得記事数）
WP_MAX_PAGES=11

# 記事ファイルの出力先フォルダ
WP_OUTPUT_DIR=./note-export

# ============================================================
# Note 設定（note-auto-post.js / note-publish-one.js で使用）
# ============================================================

# Noteのログインメールアドレス
NOTE_EMAIL=xxxx@xxxx.com

# Noteのログインパスワード
NOTE_PASSWORD=xxxxxxx

# 公開時に付与するハッシュタグ（カンマ区切り）
NOTE_TAGS=ADHD,大人の発達障害,エンジニア

# 投稿モード: draft=下書き保存 / publish=即公開
NOTE_PUBLISH_MODE=publish

# ============================================================
# アイキャッチ画像設定（note-set-eyecatch.js で使用）
# ============================================================

# 投稿モード: draft=画像設定のみ（下書き保存） / publish=画像設定後に公開まで進む
EYECATCH_PUBLISH_MODE=publish

# 処理件数の上限（テスト時は数字を入力、全件処理は Infinity）
EYECATCH_MAX_COUNT=1